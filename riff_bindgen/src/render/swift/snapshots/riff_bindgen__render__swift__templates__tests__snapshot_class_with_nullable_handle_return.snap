---
source: riff_bindgen/src/render/swift/templates.rs
expression: "render_class(&cls, \"riff\")"
---
public final class Cache {
    let handle: OpaquePointer

    init(handle: OpaquePointer) {
        self.handle = handle
    }

    deinit {
        riff_cache_free(handle)
    }

    public func get(key: String) -> CacheEntry? {
        var key = key
        return key.withUTF8 { keyBuf in
            guard let ptr = riff_cache_get(handle, keyBuf.baseAddress!, UInt(keyBuf.count)) else { return nil }
            return CacheEntry(handle: ptr)
        }
    }

}
