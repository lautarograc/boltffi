/**
 * A physical location with coordinates.
 */
data class Location(
    /**
     * Unique identifier for this location.
     */
    val id: Long,
    /**
     * Latitude in decimal degrees.
     */
    val lat: Double
) {
    companion object {
        const val SIZE_BYTES: Int = 16

        fun decode(wire: WireBuffer, offset: Int): Location {
            wire.pos = offset + SIZE_BYTES
            return Location(
                wire.readI64(offset),
                wire.readF64(offset + 8)
            )
        }
    }
    fun wireEncodedSize(): Int = SIZE_BYTES

    fun wireEncodeTo(wire: WireWriter) {
        wire.writeI64(id)
        wire.writeF64(lat)
    }
}
