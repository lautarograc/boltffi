/**
 * A cardinal compass direction.
 */
enum class Direction(val value: Int) {
    /**
     * Pointing toward the north pole.
     */
    North(0),
    South(1);

    companion object {
        fun fromValue(value: Int): Direction = entries.first { it.value == value }
    }
}
